model User {
  id String @id @default(cuid())

  email    String @unique
  password String

  balance        Int       @default(1000)
  lastPayoutDate DateTime? @map("last_payout_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email, id])
  @@map("users")
}
